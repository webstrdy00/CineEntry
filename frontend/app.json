{
  "expo": {
    "name": "CineEntry",
    "slug": "cineentry",
    "version": "1.0.0",
    "icon": "./assets/branding/cineentry-app-icon.png",
    "orientation": "portrait",
    "backgroundColor": "#1a1d29",
    "userInterfaceStyle": "dark",
    "scheme": "cineentry",
    "splash": {
      "image": "./assets/branding/cineentry-logo-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1d29"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cineentry.app"
    },
    "android": {
      "package": "com.cineentry.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/cineentry-symbol.png",
        "backgroundColor": "#E7E8E4"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/branding/cineentry-app-icon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-media-library"
    ],
    "extra": {
      "eas": {
        "projectId": "1205fd93-e1e2-43d2-8c04-f903315057ff"
      }
    }
  }
}
