{
  "expo": {
    "name": "CineEntry",
    "slug": "cineentry",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "cineentry",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cineentry.app",
      "associatedDomains": [
        "applinks:owblpingqcelupohuspg.supabase.co"
      ]
    },
    "android": {
      "package": "com.cineentry.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "owblpingqcelupohuspg.supabase.co",
              "pathPrefix": "/auth/v1/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-media-library\\"
    ]
  }
}
