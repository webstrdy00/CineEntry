# 도메인 / 브라우저 접근
API_DOMAIN=api.cineentry.com
FRONTEND_URL=https://app.cineentry.com
BACKEND_PUBLIC_URL=https://api.cineentry.com
CORS_ALLOWED_ORIGINS=https://app.cineentry.com

# 애플리케이션
APP_NAME=CineEntry API
APP_VERSION=1.0.0
DEBUG=False

# PostgreSQL / Redis
# POSTGRES_* 값과 DATABASE_URL 내용은 반드시 서로 일치해야 합니다.
POSTGRES_USER=cineentry
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=cineentry
DATABASE_URL=postgresql://cineentry:change-this-strong-password@postgres:5432/cineentry
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
AUTH_EMAIL_COOLDOWN_SECONDS=60
AUTH_LOGIN_ATTEMPT_LIMIT=10
AUTH_LOGIN_ATTEMPT_WINDOW_SECONDS=600
AUTH_REGISTER_ATTEMPT_LIMIT=5
AUTH_REGISTER_ATTEMPT_WINDOW_SECONDS=3600

# 이메일
EMAIL_FROM_ADDRESS=no-reply@cineentry.com
EMAIL_FROM_NAME=CineEntry
EMAIL_LOG_ONLY=False
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-me
SMTP_PASSWORD=replace-me
SMTP_USE_TLS=True
SMTP_USE_SSL=False

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# 외부 API
TMDB_API_KEY=
KOBIS_API_KEY=
KMDB_API_KEY=

# Google Cloud Storage
# 현재 운영 배포는 호스트의 /opt/cineentry/secrets/gcp-key.json 을 컨테이너에 마운트합니다.
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-key.json
GCP_BUCKET_NAME=
GCP_SIGNED_URL_EXPIRATION_SECONDS=900
